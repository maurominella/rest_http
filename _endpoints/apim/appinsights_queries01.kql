// App Insights - Requests in the last hour, filtering out Foundry (cloud_RoleName starts with "mmapim")
// 1. Find the transaction (== operation_Id)
// First, identify the transaction of interest (e.g., the agent invocation):

requests
| where timestamp > ago(1h)
| where name == "invoke_agent" or cloud_RoleName !startswith "mmapim" // include / exclude APIM
| project timestamp, name, cloud_RoleName, duration, success, operation_Id
| order by timestamp desc


// ----------------------------------


// App Insights - Requests, Dependencies, Traces, Custom Events, Exceptions for a specific operation_Id
// 2. End-to-end view (equivalent to Search)
let opId = "41edd7c7365ff18492cd140954b722a5";
union
  (requests     | extend itemKind="① request",    entityName=name,    entityDuration=duration),
  (dependencies | extend itemKind="→ dependency",  entityName=name,    entityDuration=duration),
  (traces       | extend itemKind="≣ trace",       entityName=message, entityDuration=real(null)),
  (customEvents | extend itemKind="◆ event",       entityName=name,    entityDuration=real(null)),
  (exceptions   | extend itemKind="✖ exception",   entityName=type,    entityDuration=real(null))
| where operation_Id == opId
| project
    timestamp,
    itemKind,
    name = entityName,
    durationMs = entityDuration,
    resultCode = column_ifexists("resultCode", ""),
    success    = column_ifexists("success", dynamic(null)),
    cloud_RoleName,
    id,
    operation_ParentId
| order by timestamp asc


// ----------------------------------


// App Insights - Graph of Requests, Dependencies, Traces, Custom Events, Exceptions for a specific operation_Id
// 3. Render it "as a tree" (hierarchical indentation)
// The tree uses the operation_ParentId → id relationship. KQL does not support arbitrary recursion, but with make-graph (graph operator) you can calculate the depth and obtain the indentation as in Search:

let opId = "506aa9189fb80941b59959c3abf9a434";
let items =
    union
      (requests     | extend itemKind="request",    entityName=name),
      (dependencies | extend itemKind="dependency",  entityName=name),
      (traces       | extend itemKind="trace",       entityName=message),
      (customEvents | extend itemKind="event",       entityName=name),
      (exceptions   | extend itemKind="exception",   entityName=type)
    | where operation_Id == opId
    | project id, parentId = operation_ParentId, itemKind, entityName,
              durationMs = column_ifexists("duration", real(null)),
              timestamp, cloud_RoleName;
// Walk up the parent chain with leftouter self-joins to compute the nesting depth,
// then build an indented "tree" column. Add more h*/hp* hops for deeper traces.
let p = items | project pid = id, pparent = parentId;
items
| join kind=leftouter (p | project h1 = pid, hp1 = pparent) on $left.parentId == $right.h1
| join kind=leftouter (p | project h2 = pid, hp2 = pparent) on $left.hp1 == $right.h2
| join kind=leftouter (p | project h3 = pid, hp3 = pparent) on $left.hp2 == $right.h3
| join kind=leftouter (p | project h4 = pid, hp4 = pparent) on $left.hp3 == $right.h4
| join kind=leftouter (p | project h5 = pid, hp5 = pparent) on $left.hp4 == $right.h5
| join kind=leftouter (p | project h6 = pid, hp6 = pparent) on $left.hp5 == $right.h6
| extend depth = tolong(isnotempty(parentId)) + tolong(isnotempty(hp1)) + tolong(isnotempty(hp2))
               + tolong(isnotempty(hp3)) + tolong(isnotempty(hp4)) + tolong(isnotempty(hp5))
               + tolong(isnotempty(hp6))
| extend tree = strcat(strrep("|   ", toint(depth)), entityName)
| project timestamp, depth, tree, itemKind, durationMs, cloud_RoleName, id, parentId
| order by timestamp asc


// ----------------------------------


// 4. Aggregated report by transaction (often more useful than Search)
// If you need a dashboard instead of a single transaction:

dependencies
| where timestamp > ago(24h)
| where cloud_RoleName !startswith "mmapim" // include / exclude APIM
| summarize
    calls = count(),
    avgDurationMs = avg(duration),
    p95Ms = percentile(duration, 95),
    errors = countif(success == false)
  by operationName = name
| order by avgDurationMs desc


// ----------------------------------


// 3b. End-to-end view with parentName (each row shows its parent node)
// Same depth/indentation as #3, plus the name of the immediate parent — handy
// when timestamps are too close together to read the hierarchy by order alone.

let opId = "506aa9189fb80941b59959c3abf9a434";
let items =
    union
      (requests     | extend itemKind="request",    entityName=name),
      (dependencies | extend itemKind="dependency",  entityName=name),
      (traces       | extend itemKind="trace",       entityName=message),
      (customEvents | extend itemKind="event",       entityName=name),
      (exceptions   | extend itemKind="exception",   entityName=type)
    | where operation_Id == opId
    | project id, parentId = operation_ParentId, itemKind, entityName,
              durationMs = column_ifexists("duration", real(null)),
              timestamp, cloud_RoleName;
// Lookup table: id -> (parentId, name) used both for depth and for parentName.
let p = items | project pid = id, pparent = parentId, pname = entityName;
items
// Resolve the immediate parent's name.
| join kind=leftouter (p | project pid, parentName = pname) on $left.parentId == $right.pid
// Walk up the chain to compute the nesting depth (add hops for deeper traces).
| join kind=leftouter (p | project h1 = pid, hp1 = pparent) on $left.parentId == $right.h1
| join kind=leftouter (p | project h2 = pid, hp2 = pparent) on $left.hp1 == $right.h2
| join kind=leftouter (p | project h3 = pid, hp3 = pparent) on $left.hp2 == $right.h3
| join kind=leftouter (p | project h4 = pid, hp4 = pparent) on $left.hp3 == $right.h4
| join kind=leftouter (p | project h5 = pid, hp5 = pparent) on $left.hp4 == $right.h5
| join kind=leftouter (p | project h6 = pid, hp6 = pparent) on $left.hp5 == $right.h6
| extend depth = tolong(isnotempty(parentId)) + tolong(isnotempty(hp1)) + tolong(isnotempty(hp2))
               + tolong(isnotempty(hp3)) + tolong(isnotempty(hp4)) + tolong(isnotempty(hp5))
               + tolong(isnotempty(hp6))
| extend tree = strcat(strrep("|   ", toint(depth)), entityName)
| project timestamp, depth, tree, parentName, itemKind, durationMs, cloud_RoleName, id, parentId
| order by timestamp asc


// ----------------------------------


// 5a. DISCOVERY — inspect the raw GenAI attributes (the "Messages" / "Generative AI
// Properties" panel on the right is just customDimensions of the LLM call).
// Run this first to see the exact key names used by your instrumentation
// (they differ across versions: gen_ai.prompt/completion vs gen_ai.input.messages/
// gen_ai.output.messages, or messages emitted as span events in the traces table).

let opId = "41edd7c7365ff18492cd140954b722a5";
union dependencies, traces, customEvents
| where operation_Id == opId
| where customDimensions has "gen_ai" or name == "chat" or message has "gen_ai"
| project timestamp, itemType, name, message, customDimensions
| order by timestamp asc


// ----------------------------------


// 5b. GenAI metadata + token usage per LLM call (the "Generative AI Properties" +
// "Custom Properties" section: model, provider, response id, input/output tokens).

let opId = "41edd7c7365ff18492cd140954b722a5";
dependencies
| where operation_Id == opId
| where isnotempty(tostring(customDimensions["gen_ai.operation.name"])) or name == "chat"
| project
    timestamp,
    operation        = tostring(customDimensions["gen_ai.operation.name"]),
    model            = tostring(customDimensions["gen_ai.request.model"]),
    provider         = tostring(customDimensions["gen_ai.provider.name"]),
    responseId       = tostring(customDimensions["gen_ai.response.id"]),
    inputTokens      = tolong(customDimensions["gen_ai.usage.input_tokens"]),
    outputTokens     = tolong(customDimensions["gen_ai.usage.output_tokens"]),
    durationMs       = duration,
    id, operation_ParentId
| order by timestamp asc


// ----------------------------------


// 5c. MESSAGES — input/output of the LLM (System / User / Generated output).
// coalesce() covers the common conventions; adjust the keys to match what 5a shows.

let opId = "41edd7c7365ff18492cd140954b722a5";
union dependencies, traces, customEvents
| where operation_Id == opId
| extend cd = todynamic(customDimensions)
| where cd has "gen_ai"
| extend
    model         = tostring(cd["gen_ai.request.model"]),
    systemInstr   = tostring(coalesce(cd["gen_ai.system_instructions"], cd["gen_ai.system.message"])),
    inputMessages = tostring(coalesce(cd["gen_ai.input.messages"], cd["gen_ai.prompt"], cd["gen_ai.user.message"])),
    output        = tostring(coalesce(cd["gen_ai.output.messages"], cd["gen_ai.completion"], cd["gen_ai.choice"]))
| project timestamp, itemType, name, model, systemInstr, inputMessages, output
| order by timestamp asc


// ----------------------------------


// 5d. MESSAGES exploded — one readable row per message part.
// gen_ai.input/output.messages = [{ "role", "parts": [{ "type":"text","content" }
//                                  | { "type":"tool_call","id","name","arguments" }] }]
// Double mv-expand (messages -> parts) flattens both input and output into rows.

let opId = "41edd7c7365ff18492cd140954b722a5";
dependencies
| where operation_Id == opId
| where isnotempty(tostring(customDimensions["gen_ai.input.messages"]))
     or isnotempty(tostring(customDimensions["gen_ai.output.messages"]))
| project timestamp, callId = id,
          model      = tostring(customDimensions["gen_ai.request.model"]),
          inputMsgs  = parse_json(tostring(customDimensions["gen_ai.input.messages"])),
          outputMsgs = parse_json(tostring(customDimensions["gen_ai.output.messages"]))
| mv-expand direction = pack_array("input", "output") to typeof(string)
| extend msgs = iff(direction == "input", inputMsgs, outputMsgs)
| mv-expand msg = msgs
| mv-expand part = msg.parts
| project timestamp, callId, model, direction,
          role     = tostring(msg.role),
          partType = tostring(part.type),
          content  = tostring(part.content),
          toolName = tostring(part.name),
          toolArgs = tostring(part.arguments)
| order by timestamp asc, direction asc


// ----------------------------------


// 6a. CORRELATION CHECK — does APIM share the same operation_Id (W3C trace) as Foundry?
// APIM and Foundry land in the SAME App Insights but are the SAME interaction only if
// the traceparent propagates from APIM into the agent runtime. If 'foundryRole' is
// populated, the two sides share operation_Id and can be joined directly (see 6b).
// If it stays empty, the agent started a new trace -> see the note at the bottom.

let apimRole = "mmapim";   // <-- set your APIM service name (its cloud_RoleName prefix)
requests
| where timestamp > ago(1h)
| where cloud_RoleName startswith apimRole
| project apimTime = timestamp, operation_Id, apimApi = name, url, resultCode
| join kind=leftouter (
    union dependencies, traces, requests
    | where customDimensions has "gen_ai"
    | distinct operation_Id, foundryRole = cloud_RoleName
  ) on operation_Id
| project apimTime, operation_Id, apimApi, url, resultCode, foundryRole
| order by apimTime desc


// ----------------------------------


// 6b. SINGLE INTERACTION across APIM + Foundry, tagged by source.
// One unified, source-labelled view for a given operation_Id: APIM requests/dependencies
// + the OpenAIUsage token metric (customMetrics) + all Foundry spans/traces.

let opId = "41edd7c7365ff18492cd140954b722a5";
let apimRole = "mmapim";   // <-- same APIM service name prefix as above
union requests, dependencies, traces, customMetrics
| where operation_Id == opId
| extend source = iff(cloud_RoleName startswith apimRole, "APIM", "Foundry")
| extend entity = coalesce(tostring(name), tostring(message))
| project timestamp,
          source,
          itemType,
          entity,
          durationMs  = column_ifexists("duration", real(null)),
          resultCode  = tostring(column_ifexists("resultCode", "")),
          metricValue = column_ifexists("value", real(null)),   // token counts for OpenAIUsage rows
          details     = customDimensions,                       // APIM metric dimensions / Foundry gen_ai.*
          cloud_RoleName
| order by timestamp asc


// ----------------------------------


// 6a-bis. DISCOVERY for correlation — confirm the thread id is present on BOTH sides.
// (APIM and Foundry do NOT share operation_Id when traceparent isn't propagated,
//  so we bridge them on the agent thread id, which both naturally carry.)
// Inspect where the thread id appears, then tune the regex/keys used in 6c.

let apimRole = "mmapim";
union requests, dependencies
| where timestamp > ago(24h)
| where url has "threads" or name has "threads" or data has "threads"
     or customDimensions has "thread"
| extend side = iff(cloud_RoleName startswith apimRole, "APIM", "Foundry")
| project timestamp, side, itemType, name,
          url = column_ifexists("url", ""), data = column_ifexists("data", ""),
          customDimensions, cloud_RoleName
| order by timestamp desc


// ----------------------------------


// 6a-ter. APIM side only — does the REAL thread id ever reach APIM telemetry?
// In 6a-bis the APIM rows showed the templated url "/threads/*" (and were GET noise).
// This isolates real agent calls (POST runs) and dumps the full url + every dimension,
// so you can see whether a concrete "thread_XXX" value exists anywhere on the APIM side.
// If it does NOT  -> APIM logs only the url template; capture it via policy (see note).

let apimRole = "mmapim";
requests
| where timestamp > ago(24h)
| where cloud_RoleName startswith apimRole
| where url has "threads" or url has "runs" or name has "runs"
| extend method = tostring(customDimensions["HTTP Method"])
| project timestamp, method, name, url, resultCode,
          urlHasConcreteThread = url matches regex @"thread_[A-Za-z0-9]+",
          customDimensions
| order by timestamp desc


// ----------------------------------


// 6c. CORRELATE APIM <-> Foundry on the agent thread id (no trace propagation needed).
// Bridges the two separate traces: one APIM call <-> all Foundry spans for that thread.
// After this, drill into each side with apimOpId / foundryOpId using queries #2, #5x, #6b.

let apimRole = "mmapim";
let lookback = 24h;
let apimSide =
    requests
    | where timestamp > ago(lookback)
    | where cloud_RoleName startswith apimRole
    | extend threadId = extract(@"threads/([^/?]+)", 1, url)
    | where isnotempty(threadId)
    | project apimTime = timestamp, threadId, apimApi = name, apimUrl = url,
              apimResult = resultCode, apimDurationMs = duration, apimOpId = operation_Id;
let foundrySide =
    union dependencies, requests
    | where timestamp > ago(lookback)
    | where cloud_RoleName !startswith apimRole
    | extend threadId = coalesce(
            tostring(customDimensions["gen_ai.thread.id"]),
            tostring(customDimensions["gen_ai.conversation.id"]),
            extract(@"threads/([^/?]+)", 1, tostring(column_ifexists("url", ""))),
            extract(@"threads/([^/?]+)", 1, tostring(column_ifexists("data", ""))),
            extract(@"threads/([^/?]+)", 1, name))
    | where isnotempty(threadId)
    | summarize foundryOpId   = take_any(operation_Id),
                foundryRoles  = make_set(cloud_RoleName),
                foundryStart  = min(timestamp),
                foundryEnd    = max(timestamp),
                foundrySpans  = count()
      by threadId;
apimSide
| join kind=inner foundrySide on threadId
| project apimTime, threadId,
          apimApi, apimResult, apimDurationMs, apimOpId,
          foundryOpId, foundryRoles, foundryStart, foundryEnd, foundrySpans
| order by apimTime desc


// ----------------------------------


// 7. SIMPLE per-call report: Foundry LLM input/output + APIM client IP.
// The ONLY prerequisite is one extra dimension on the token-metric policy:
//   <dimension name="Thread ID" value="@(...thread id from request path...)" />
// so the OpenAIUsage metric carries both Client IP and the thread id used to join.

let lookback = 24h;
// (a) thread id per Foundry operation (from any span carrying /threads/{id})
let foundryThread =
    union dependencies, requests
    | where timestamp > ago(lookback)
    | extend threadId = coalesce(
        tostring(customDimensions["gen_ai.thread.id"]),
        extract(@"threads/([^/?]+)", 1, tostring(column_ifexists("data", ""))),
        extract(@"threads/([^/?]+)", 1, tostring(column_ifexists("url", ""))),
        extract(@"threads/([^/?]+)", 1, name))
    | where isnotempty(threadId)
    | summarize threadId = take_any(threadId) by operation_Id;
// (b) LLM input/output per Foundry operation
let foundryMsgs =
    dependencies
    | where timestamp > ago(lookback)
    | where isnotempty(tostring(customDimensions["gen_ai.input.messages"]))
    | project opTime  = timestamp, operation_Id,
              model   = tostring(customDimensions["gen_ai.request.model"]),
              input   = tostring(customDimensions["gen_ai.input.messages"]),
              output  = tostring(customDimensions["gen_ai.output.messages"]);
// (c) client IP per thread, from the APIM OpenAIUsage metric (needs the Thread ID dimension)
let apimIp =
    customMetrics
    | where timestamp > ago(lookback)
    | where customDimensions has "Client IP"
    | extend threadId = tostring(customDimensions["Thread ID"]),
             clientIp = tostring(customDimensions["Client IP"])
    | where isnotempty(threadId)
    | summarize clientIp = take_any(clientIp) by threadId;
foundryMsgs
| join kind=leftouter foundryThread on operation_Id
| join kind=leftouter apimIp on threadId
| project opTime, threadId, clientIp, model, input, output
| order by opTime desc


// ----------------------------------


// 7-check. Is the OpenAIUsage token metric even emitted (with Client IP)?
// If this returns 0 rows, azure-openai-emit-token-metric never fires for agent RUN
// calls (no synchronous OpenAI 'usage' to parse) -> emit Client IP via <trace> instead.

customMetrics
| where timestamp > ago(24h)
| where customDimensions has "Client IP"
| project timestamp, name, value, customDimensions
| take 50


// ----------------------------------


// 7-trace. SAME as #7 but the client IP comes from an APIM <trace> (always emitted),
// not from the token metric. Add this to <inbound>:
//   <set-variable name="threadId" value="@(Regex.Match(context.Request.Url.Path,"thread_[A-Za-z0-9]+").Value)" />
//   <trace source="apim-client" severity="information">
//     <metadata name="ClientIP" value="@(context.Request.IpAddress)" />
//     <metadata name="ThreadID" value="@((string)context.Variables.GetValueOrDefault("threadId",""))" />
//   </trace>

let lookback = 24h;
let foundryThread =
    union dependencies, requests
    | where timestamp > ago(lookback)
    | extend threadId = coalesce(
        tostring(customDimensions["gen_ai.thread.id"]),
        extract(@"threads/([^/?]+)", 1, tostring(column_ifexists("data", ""))),
        extract(@"threads/([^/?]+)", 1, tostring(column_ifexists("url", ""))),
        extract(@"threads/([^/?]+)", 1, name))
    | where isnotempty(threadId)
    | summarize threadId = take_any(threadId) by operation_Id;
let foundryMsgs =
    dependencies
    | where timestamp > ago(lookback)
    | where isnotempty(tostring(customDimensions["gen_ai.input.messages"]))
    | project opTime  = timestamp, operation_Id,
              model   = tostring(customDimensions["gen_ai.request.model"]),
              input   = tostring(customDimensions["gen_ai.input.messages"]),
              output  = tostring(customDimensions["gen_ai.output.messages"]);
// client IP per thread, from the APIM <trace> (traces table) instead of customMetrics.
let apimIp =
    traces
    | where timestamp > ago(lookback)
    | where customDimensions has "ThreadID" or customDimensions has "ClientIP"
    | extend threadId = tostring(customDimensions["ThreadID"]),
             clientIp = tostring(customDimensions["ClientIP"])
    | where isnotempty(threadId)
    | summarize clientIp = take_any(clientIp) by threadId;
foundryMsgs
| join kind=leftouter foundryThread on operation_Id
| join kind=leftouter apimIp on threadId
| project opTime, threadId, clientIp, model, input, output
| order by opTime desc